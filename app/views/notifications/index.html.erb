<% content_for(:title) { "Notifications — Cluckbait" } %>

<section class="section">
  <div class="container container-narrow">
    <div class="notifications-header">
      <h1 class="section-title">🔔 Notifications</h1>
      <% if @notifications.any? { |n| n.unread? } %>
        <%= button_to "Mark all as read", mark_all_as_read_notifications_path, class: "btn btn-outline btn-sm" %>
      <% end %>
    </div>

    <div id="notifications-list">
      <% if @notifications.any? %>
        <% @notifications.each do |notification| %>
          <%= render partial: "notification", locals: { notification: notification } %>
        <% end %>
      <% else %>
        <div class="empty-state">
          <span class="empty-icon">🔔</span>
          <h3>No notifications yet</h3>
          <p>When something happens — friend requests, messages, and more — you'll see it here.</p>
        </div>
      <% end %>
    </div>
  </div>
</section>
