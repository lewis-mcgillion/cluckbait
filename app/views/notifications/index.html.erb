<% content_for(:title) { t("notifications.title") } %>

<section class="section">
  <div class="container container-narrow">
    <div class="notifications-header" id="notifications-header">
      <h1 class="section-title"><%= t("notifications.heading") %></h1>
      <% if @notifications.any? { |n| n.unread? } %>
        <%= button_to t("notifications.mark_all_read"), mark_all_as_read_notifications_path, class: "btn btn-outline btn-sm" %>
      <% end %>
    </div>

    <div id="notifications-list">
      <% if @notifications.any? %>
        <% @notifications.each do |notification| %>
          <%= render partial: "notification", locals: { notification: notification } %>
        <% end %>
        <%= render "shared/pagination" %>
      <% else %>
        <div class="empty-state">
          <span class="empty-icon">🔔</span>
          <h3><%= t("notifications.no_notifications") %></h3>
          <p><%= t("notifications.no_notifications_hint") %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>
