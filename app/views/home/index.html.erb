<% content_for(:title) { t("home.title") } %>

<div data-controller="map">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-title">
        <%= t("home.hero_title_html") %>
      </h1>
      <p class="hero-subtitle">
        <%= t("home.hero_subtitle") %>
      </p>
      <div class="hero-search">
        <div class="search-box">
          <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input type="text"
                 data-map-target="searchInput"
                 data-action="input->map#search"
                 placeholder="<%= t("home.search_placeholder") %>"
                 class="search-input"
                 aria-label="<%= t("home.search_aria") %>"
                 autocomplete="off">
          <button data-action="click->map#locate"
                  class="btn btn-accent btn-locate"
                  title="<%= t("home.use_my_location") %>">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
              <circle cx="12" cy="12" r="3"/><path d="M12 2v4M12 18v4M2 12h4M18 12h4"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="map-section">
    <div data-map-target="container" id="map" class="main-map"></div>
  </section>
</div>

<!-- Top Rated Shops -->
<% if @top_shops.any? %>
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title"><%= t("home.top_rated") %></h2>
      <p class="section-subtitle"><%= t("home.top_rated_subtitle") %></p>
    </div>
    <div class="shops-grid">
      <% @top_shops.each do |shop| %>
        <%= render "chicken_shops/card", shop: shop %>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- Recent Reviews -->
<% if @recent_reviews.any? %>
<section class="section section-dark">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title"><%= t("home.latest_reviews") %></h2>
      <p class="section-subtitle"><%= t("home.latest_reviews_subtitle") %></p>
    </div>
    <div class="reviews-grid">
      <% @recent_reviews.each do |review| %>
        <%= render "reviews/mini_card", review: review %>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- Top Contributors -->
<% if @top_contributors.any? %>
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title"><%= t("home.top_contributors") %></h2>
      <p class="section-subtitle"><%= t("home.top_contributors_subtitle") %></p>
    </div>
    <div class="contributors-grid">
      <% @top_contributors.each_with_index do |contributor, index| %>
        <%= link_to profile_path(contributor), class: "contributor-card" do %>
          <span class="contributor-rank">
            <% if index == 0 %> 🥇
            <% elsif index == 1 %> 🥈
            <% elsif index == 2 %> 🥉
            <% else %> #<%= index + 1 %>
            <% end %>
          </span>
          <% if contributor.avatar.attached? %>
            <%= image_tag contributor.avatar.variant(resize_to_fill: [48, 48]), class: "contributor-avatar" %>
          <% else %>
            <span class="contributor-avatar-placeholder"><%= contributor.name[0].upcase %></span>
          <% end %>
          <span class="contributor-name"><%= contributor.name %></span>
          <span class="contributor-score"><%= contributor.reviews_score %> <%= t("shared.reviews") %></span>
        <% end %>
      <% end %>
    </div>
    <%= link_to t("home.view_leaderboard"), leaderboard_path, class: "btn btn-outline" %>
  </div>
</section>
<% end %>

<!-- CTA Section -->
<section class="section cta-section">
  <div class="container text-center">
    <% if user_signed_in? %>
      <h2 class="section-title"><%= t("home.cta_title") %></h2>
      <p class="section-subtitle"><%= t("home.cta_signed_in") %></p>
    <% else %>
      <h2 class="section-title"><%= t("home.cta_title") %></h2>
      <p class="section-subtitle"><%= t("home.cta_signed_out") %></p>
      <%= link_to t("home.create_free_account"), new_user_registration_path, class: "btn btn-primary btn-lg" %>
    <% end %>
    <%= link_to t("home.browse_all_shops"), chicken_shops_path, class: "btn btn-outline btn-lg" %>
  </div>
</section>
