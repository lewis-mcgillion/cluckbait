<% content_for(:title) { t("activities.title") } %>

<div class="page-header">
  <div class="container">
    <h1 class="page-title"><%= t("activities.heading") %></h1>
    <p class="page-subtitle"><%= t("activities.subtitle") %></p>
  </div>
</div>

<div class="container" style="padding: 2rem 1.5rem;">
  <%= turbo_stream_from current_user, :activities %>
  <% if @activities.any? %>
    <div class="activity-feed" id="activity-feed">
      <%= render partial: "activity", collection: @activities %>
    </div>

    <% if @activities.size == 20 %>
      <div class="activity-load-more">
        <%= link_to t("activities.load_more"), activities_path(page: @page + 1), class: "btn btn-outline" %>
      </div>
    <% end %>
  <% elsif @page > 1 %>
    <div class="empty-state">
      <div class="empty-state-icon">📄</div>
      <h3><%= t("activities.no_more_activity", default: "No more activity") %></h3>
      <p class="text-muted"><%= t("activities.no_more_hint", default: "You've reached the end of the feed.") %></p>
      <%= link_to t("activities.heading", default: "Activity Feed"), activities_path, class: "btn btn-primary" %>
    </div>
  <% else %>
    <div class="empty-state">
      <div class="empty-state-icon">📡</div>
      <h3><%= t("activities.no_activity") %></h3>
      <p class="text-muted"><%= t("activities.no_activity_hint") %></p>
      <%= link_to t("activities.find_friends"), friendships_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
