<%= turbo_frame_tag dom_id(review) do %>
  <div class="review-card">
    <div class="review-header">
      <div class="review-author-info">
        <%= link_to profile_path(review.user), class: "review-author-link", data: { turbo_frame: "_top" } do %>
          <% if review.user.avatar.attached? %>
            <%= image_tag review.user.avatar.variant(resize_to_fill: [40, 40]), class: "review-avatar" %>
          <% else %>
            <div class="review-avatar-placeholder"><%= review.user.name[0].upcase %></div>
          <% end %>
          <div>
            <span class="review-author-name"><%= review.user.name %></span>
            <span class="review-date"><%= review.created_at.strftime("%d %b %Y") %></span>
          </div>
        <% end %>
      </div>
      <div class="review-rating-badge">
        <span class="review-stars"><%= "★" * review.rating %><%= "☆" * (5 - review.rating) %></span>
        <span class="review-label"><%= review.rating_label %></span>
      </div>
    </div>

    <h4 class="review-title"><%= review.title %></h4>
    <p class="review-body"><%= review.body %></p>

    <% if review.photos.attached? %>
      <div class="review-photos">
        <% review.photos.each do |photo| %>
          <%= image_tag photo.variant(resize_to_limit: [600, 400]), class: "review-photo" %>
        <% end %>
      </div>
    <% end %>

    <% if defined?(current_user) && current_user == review.user %>
      <div class="review-actions">
        <%= button_to t("reviews.delete"), chicken_shop_review_path(chicken_shop, review), method: :delete, class: "btn btn-danger btn-sm", data: { turbo_confirm: t("reviews.delete_confirm") } %>
      </div>
    <% end %>

    <%= render "reviews/reaction_bar", review: review, current_user: (defined?(current_user) ? current_user : nil) %>
  </div>
<% end %>
