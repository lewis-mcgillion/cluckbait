<% content_for(:title) { t("pages.privacy_policy.title") } %>
<% content_for(:meta_description) { t("pages.privacy_policy.meta_description") } %>

<div class="legal-page">
  <div class="container">
    <h1><%= t("pages.privacy_policy.heading") %></h1>
    <p class="legal-updated"><%= t("pages.privacy_policy.last_updated", date: "16 March 2026") %></p>

    <div class="legal-content">
      <section>
        <h2><%= t("pages.privacy_policy.sections.intro.title") %></h2>
        <p><%= t("pages.privacy_policy.sections.intro.body") %></p>
      </section>

      <section>
        <h2><%= t("pages.privacy_policy.sections.data_collected.title") %></h2>
        <p><%= t("pages.privacy_policy.sections.data_collected.body") %></p>
        <ul>
          <% t("pages.privacy_policy.sections.data_collected.items").each do |item| %>
            <li><%= item %></li>
          <% end %>
        </ul>
      </section>

      <section>
        <h2><%= t("pages.privacy_policy.sections.how_we_use.title") %></h2>
        <p><%= t("pages.privacy_policy.sections.how_we_use.body") %></p>
        <ul>
          <% t("pages.privacy_policy.sections.how_we_use.items").each do |item| %>
            <li><%= item %></li>
          <% end %>
        </ul>
      </section>

      <section>
        <h2><%= t("pages.privacy_policy.sections.third_parties.title") %></h2>
        <p><%= t("pages.privacy_policy.sections.third_parties.body") %></p>
        <ul>
          <% t("pages.privacy_policy.sections.third_parties.items").each do |item| %>
            <li><%= item %></li>
          <% end %>
        </ul>
      </section>

      <section>
        <h2><%= t("pages.privacy_policy.sections.cookies.title") %></h2>
        <p><%= t("pages.privacy_policy.sections.cookies.body") %></p>
      </section>

      <section>
        <h2><%= t("pages.privacy_policy.sections.your_rights.title") %></h2>
        <p><%= t("pages.privacy_policy.sections.your_rights.body") %></p>
        <ul>
          <% t("pages.privacy_policy.sections.your_rights.items").each do |item| %>
            <li><%= item %></li>
          <% end %>
        </ul>
      </section>

      <section>
        <h2><%= t("pages.privacy_policy.sections.data_retention.title") %></h2>
        <p><%= t("pages.privacy_policy.sections.data_retention.body") %></p>
      </section>

      <section>
        <h2><%= t("pages.privacy_policy.sections.contact.title") %></h2>
        <p><%= t("pages.privacy_policy.sections.contact.body") %></p>
      </section>
    </div>
  </div>
</div>
