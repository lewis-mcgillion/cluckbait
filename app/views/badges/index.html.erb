<% content_for(:title) { t("badges.title") } %>

<section class="section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title"><%= t("badges.title") %></h2>
      <p class="section-subtitle"><%= t("badges.subtitle") %></p>
    </div>

    <div class="badges-grid">
      <% @badges.each do |badge| %>
        <div class="badge-card <%= 'badge-earned' if @earned_badge_ids.include?(badge.id) %>">
          <div class="badge-icon-large"><%= badge.icon %></div>
          <h3 class="badge-name"><%= badge.name %></h3>
          <p class="badge-description"><%= badge.description %></p>
          <% if user_signed_in? %>
            <% if @earned_badge_ids.include?(badge.id) %>
              <span class="badge-status earned"><%= t("badges.earned") %></span>
            <% else %>
              <div class="badge-progress">
                <% progress = badge.progress_for(current_user) %>
                <div class="progress-bar">
                  <div class="progress-fill" style="width: <%= [progress.to_f / badge.threshold * 100, 100].min %>%"></div>
                </div>
                <span class="progress-text"><%= progress %> / <%= badge.threshold %></span>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>
