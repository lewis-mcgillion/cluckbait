<nav class="navbar">
  <div class="nav-container">
    <div class="nav-left">
      <%= link_to root_path, class: "nav-logo" do %>
        <span class="logo-icon">🍗</span>
        <span class="logo-text">Cluckbait</span>
      <% end %>
    </div>

    <div class="nav-center">
      <%= link_to "Home", root_path, class: "nav-link #{'active' if current_page?(root_path)}" %>
      <% if user_signed_in? %>
        <%= link_to "Feed", activities_path, class: "nav-link #{'active' if current_page?(activities_path)}" %>
      <% end %>
      <%= link_to "All Shops", chicken_shops_path, class: "nav-link #{'active' if current_page?(chicken_shops_path)}" %>
      <% if user_signed_in? %>
        <% wishlist = current_user.wishlist_count %>
        <% pending_friends = current_user.pending_friend_requests_count %>
        <% unread_convos = current_user.unread_conversations_count %>
        <%= link_to wishlist_items_path, class: "nav-link #{'active' if current_page?(wishlist_items_path)}" do %>
          Wishlist
          <span id="wishlist_nav_count">
            <% if wishlist > 0 %>
              <span class="nav-badge"><%= wishlist %></span>
            <% end %>
          </span>
        <% end %>
        <%= link_to friendships_path, class: "nav-link #{'active' if current_page?(friendships_path)}" do %>
          Friends
          <% if pending_friends > 0 %>
            <span class="nav-badge"><%= pending_friends %></span>
          <% end %>
        <% end %>
        <%= link_to conversations_path, class: "nav-link #{'active' if current_page?(conversations_path)}" do %>
          Messages
          <% if unread_convos > 0 %>
            <span class="nav-badge"><%= unread_convos %></span>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <div class="nav-right">
      <% if user_signed_in? %>
        <%= link_to notifications_path, class: "nav-link nav-bell #{'active' if current_page?(notifications_path)}" do %>
          🔔
          <% if current_user.unread_notifications_count > 0 %>
            <span class="nav-badge"><%= current_user.unread_notifications_count %></span>
          <% end %>
        <% end %>
        <div class="nav-user-menu">
          <%= link_to profile_path(current_user), class: "nav-avatar-link" do %>
            <% if current_user.avatar.attached? %>
              <%= image_tag current_user.avatar, class: "nav-avatar" %>
            <% else %>
              <div class="nav-avatar-placeholder"><%= current_user.name[0].upcase %></div>
            <% end %>
            <span class="nav-username"><%= current_user.name %></span>
          <% end %>
          <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link nav-signout" %>
        </div>
      <% else %>
        <%= link_to "Sign in", new_user_session_path, class: "nav-link" %>
        <%= link_to "Join", new_user_registration_path, class: "btn btn-primary btn-sm" %>
      <% end %>
    </div>
  </div>
</nav>
