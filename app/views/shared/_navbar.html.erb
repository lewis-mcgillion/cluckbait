<nav class="navbar" data-controller="mobile-nav">
  <% if user_signed_in? %>
    <%= turbo_stream_from current_user, :notifications %>
  <% end %>
  <div class="nav-container">
    <div class="nav-left">
      <%= link_to root_path, class: "nav-logo" do %>
        <span class="logo-icon">🍗</span>
        <span class="logo-text">Cluckbait</span>
      <% end %>
    </div>

    <button class="nav-hamburger" data-action="click->mobile-nav#toggle" aria-label="<%= t('navbar.toggle_menu') %>" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <div class="nav-center" data-mobile-nav-target="menu">
      <%= link_to t("navbar.home"), root_path, class: "nav-link #{'active' if current_page?(root_path)}" %>
      <% if user_signed_in? %>
        <%= link_to t("navbar.feed"), activities_path, class: "nav-link #{'active' if current_page?(activities_path)}" %>
      <% end %>
      <%= link_to t("navbar.all_shops"), chicken_shops_path, class: "nav-link #{'active' if current_page?(chicken_shops_path)}" %>
      <% if user_signed_in? %>
        <% wishlist = current_user.wishlist_count %>
        <% pending_friends = current_user.pending_friend_requests_count %>
        <% unread_convos = current_user.unread_conversations_count %>
        <%= link_to wishlist_items_path, class: "nav-link #{'active' if current_page?(wishlist_items_path)}" do %>
          <%= t("navbar.wishlist") %>
          <span id="wishlist_nav_count">
            <% if wishlist > 0 %>
              <span class="nav-badge"><%= wishlist %></span>
            <% end %>
          </span>
        <% end %>
        <%= link_to friendships_path, class: "nav-link #{'active' if current_page?(friendships_path) || current_page?(users_path)}" do %>
          <%= t("navbar.friends") %>
          <% if pending_friends > 0 %>
            <span class="nav-badge"><%= pending_friends %></span>
          <% end %>
        <% end %>
        <%= link_to conversations_path, class: "nav-link #{'active' if current_page?(conversations_path)}" do %>
          <%= t("navbar.messages") %>
          <% if unread_convos > 0 %>
            <span class="nav-badge"><%= unread_convos %></span>
          <% end %>
        <% end %>
        <%= link_to t("shared.sign_out"), destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link nav-signout-mobile" %>
      <% end %>
    </div>

    <div class="nav-right">
      <% if user_signed_in? %>
        <%= link_to notifications_path, class: "nav-link nav-bell #{'active' if current_page?(notifications_path)}", aria: { label: t("navbar.notifications", default: "Notifications") } do %>
          🔔
          <span id="notification-badge">
          <% unread_count = current_user.unread_notifications_count %>
          <% if unread_count > 0 %>
            <span class="nav-badge"><%= unread_count %></span>
          <% end %>
          </span>
        <% end %>
        <div class="nav-user-menu">
          <%= link_to profile_path(current_user), class: "nav-avatar-link" do %>
            <% if current_user.avatar.attached? %>
              <%= image_tag current_user.avatar, class: "nav-avatar" %>
            <% else %>
              <div class="nav-avatar-placeholder"><%= current_user.name[0].upcase %></div>
            <% end %>
            <span class="nav-username"><%= current_user.name %></span>
          <% end %>
          <%= link_to t("shared.sign_out"), destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link nav-signout" %>
        </div>
      <% else %>
        <%= link_to t("shared.sign_in"), new_user_session_path, class: "nav-link" %>
        <%= link_to t("shared.join"), new_user_registration_path, class: "btn btn-primary btn-sm" %>
      <% end %>
    </div>
  </div>
</nav>
