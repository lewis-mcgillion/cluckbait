<footer class="footer">
  <div class="footer-container">
    <div class="footer-brand">
      <span class="logo-icon">🍗</span>
      <span class="logo-text">Cluckbait</span>
      <p class="footer-tagline"><%= t("footer.tagline") %></p>
    </div>
    <div class="footer-links">
      <div class="footer-col">
        <h3><%= t("footer.explore") %></h3>
        <%= link_to t("navbar.home"), root_path %>
        <%= link_to t("navbar.all_shops"), chicken_shops_path %>
      </div>
      <div class="footer-col">
        <h3><%= t("footer.account") %></h3>
        <% if user_signed_in? %>
          <%= link_to t("footer.my_profile"), profile_path(current_user) %>
          <%= link_to t("shared.sign_out"), destroy_user_session_path, data: { turbo_method: :delete } %>
        <% else %>
          <%= link_to t("shared.sign_in"), new_user_session_path %>
          <%= link_to t("footer.join_cluckbait"), new_user_registration_path %>
        <% end %>
      </div>
      <div class="footer-col">
        <h3><%= t("footer.legal") %></h3>
        <%= link_to t("footer.privacy_policy"), privacy_policy_path %>
        <%= link_to t("footer.terms"), terms_path %>
        <%= link_to t("footer.cookie_policy"), cookie_policy_path %>
      </div>
      <div class="footer-col">
        <div class="language-selector">
          <%= form_tag update_locale_path, method: :patch, data: { turbo: false } do %>
            <select name="locale_preference" class="language-select" aria-label="<%= t('footer.language') %>" data-controller="locale" data-action="change->locale#change">
              <% I18n.available_locales.sort_by { |loc| locale_name(loc) }.each do |loc| %>
                <option value="<%= loc %>" <%= "selected" if loc == I18n.locale %>><%= locale_name(loc) %></option>
              <% end %>
            </select>
          <% end %>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p><%= t("footer.copyright", year: Date.today.year) %></p>
    </div>
  </div>
</footer>
