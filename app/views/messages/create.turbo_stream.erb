<%= turbo_stream.append "chat-messages" do %>
  <%= render "messages/message", message: @message %>
<% end %>

<%= turbo_stream.replace "message_form_body" do %>
  <input type="text" name="message[body]" id="message_body" class="chat-input" placeholder="Type a message..." autocomplete="off" data-message-form-target="input">
<% end %>
