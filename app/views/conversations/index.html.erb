<% content_for(:title) { t("conversations.title") } %>

<section class="section">
  <div class="container">
    <div class="messages-page-header">
      <h1 class="section-title"><%= t("conversations.heading") %></h1>
    </div>

    <% if @conversations.any? %>
      <div class="conversations-list">
        <% @conversations.each do |conversation| %>
          <% other = conversation.other_user(current_user) %>
          <% last_msg = conversation.last_message %>
          <%= link_to conversation_path(conversation), class: "conversation-preview" do %>
            <div class="conversation-avatar">
              <% if other.avatar.attached? %>
                <%= image_tag other.avatar, class: "conversation-avatar-img" %>
              <% else %>
                <div class="conversation-avatar-placeholder"><%= other.name[0].upcase %></div>
              <% end %>
            </div>
            <div class="conversation-info">
              <div class="conversation-header">
                <span class="conversation-name"><%= other.name %></span>
                <% if last_msg %>
                  <span class="conversation-time"><%= time_ago_in_words(last_msg.created_at) %> <%= t("shared.ago") %></span>
                <% end %>
              </div>
              <% if last_msg %>
                <p class="conversation-snippet">
                  <% if last_msg.shareable.present? %>
                    <span class="shared-badge-sm">📎</span>
                  <% end %>
                  <%= truncate(last_msg.body || "Shared a #{last_msg.shareable_type&.underscore&.humanize&.downcase}", length: 60) %>
                </p>
              <% else %>
                <p class="conversation-snippet text-muted"><%= t("conversations.no_messages_yet") %></p>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
      <%= render "shared/pagination" %>
    <% else %>
      <div class="empty-state">
        <span class="empty-icon">💬</span>
        <h3><%= t("conversations.no_conversations") %></h3>
        <p><%= t("conversations.no_conversations_hint") %></p>
        <%= link_to t("conversations.view_friends"), friendships_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</section>
