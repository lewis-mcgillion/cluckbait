<% content_for(:title) { t("friendships.title") } %>

<section class="section">
  <div class="container">
    <div class="friends-page-header">
      <h1 class="section-title"><%= t("friendships.heading") %></h1>
    </div>

    <% if @pending_requests.any? %>
      <div class="friends-section">
        <h2 class="subsection-title"><%= t("friendships.friend_requests", count: @pending_requests.count) %></h2>
        <div class="friends-grid">
          <% @pending_requests.each do |friendship| %>
            <div class="friend-card friend-card-pending">
              <div class="friend-card-info">
                <%= link_to profile_path(friendship.user), class: "friend-avatar-link" do %>
                  <% if friendship.user.avatar.attached? %>
                    <%= image_tag friendship.user.avatar, class: "friend-avatar" %>
                  <% else %>
                    <div class="friend-avatar-placeholder"><%= friendship.user.name[0].upcase %></div>
                  <% end %>
                <% end %>
                <div class="friend-details">
                  <%= link_to friendship.user.name, profile_path(friendship.user), class: "friend-name" %>
                  <span class="friend-meta"><%= friendship.user.reviews_count %> <%= t("shared.reviews") %></span>
                </div>
              </div>
              <div class="friend-card-actions">
                <%= button_to t("shared.accept"), friendship_path(friendship), method: :patch, class: "btn btn-primary btn-sm" %>
                <%= button_to t("shared.decline"), friendship_path(friendship), method: :delete, class: "btn btn-danger btn-sm" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @sent_requests.any? %>
      <div class="friends-section">
        <h2 class="subsection-title"><%= t("friendships.sent_requests", count: @sent_requests.count) %></h2>
        <div class="friends-grid">
          <% @sent_requests.each do |friendship| %>
            <div class="friend-card friend-card-sent">
              <div class="friend-card-info">
                <%= link_to profile_path(friendship.friend), class: "friend-avatar-link" do %>
                  <% if friendship.friend.avatar.attached? %>
                    <%= image_tag friendship.friend.avatar, class: "friend-avatar" %>
                  <% else %>
                    <div class="friend-avatar-placeholder"><%= friendship.friend.name[0].upcase %></div>
                  <% end %>
                <% end %>
                <div class="friend-details">
                  <%= link_to friendship.friend.name, profile_path(friendship.friend), class: "friend-name" %>
                  <span class="friend-meta"><%= t("friendships.pending") %></span>
                </div>
              </div>
              <div class="friend-card-actions">
                <%= button_to t("shared.cancel"), friendship_path(friendship), method: :delete, class: "btn btn-outline btn-sm" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="friends-section">
      <h2 class="subsection-title"><%= t("friendships.your_friends", count: @friends.count) %></h2>
      <% if @friends.any? %>
        <div class="friends-grid">
          <% @friends.each do |friend| %>
            <div class="friend-card">
              <div class="friend-card-info">
                <%= link_to profile_path(friend), class: "friend-avatar-link" do %>
                  <% if friend.avatar.attached? %>
                    <%= image_tag friend.avatar, class: "friend-avatar" %>
                  <% else %>
                    <div class="friend-avatar-placeholder"><%= friend.name[0].upcase %></div>
                  <% end %>
                <% end %>
                <div class="friend-details">
                  <%= link_to friend.name, profile_path(friend), class: "friend-name" %>
                  <span class="friend-meta"><%= friend.reviews_count %> <%= "review".pluralize(friend.reviews_count) %><% if friend.average_rating_given %> · Avg ★ <%= friend.average_rating_given %><% end %></span>
                </div>
              </div>
              <div class="friend-card-actions">
                <%= button_to t("profiles.show.message"), conversations_path(receiver_id: friend.id), method: :post, class: "btn btn-primary btn-sm" %>
                <% friendship = @friendships_by_friend&.dig(friend.id) || current_user.friendship_with(friend) %>
                <% if friendship %>
                  <%= button_to t("shared.remove"), friendship_path(friendship), method: :delete, class: "btn btn-outline btn-sm", data: { turbo_confirm: t("friendships.remove_confirm", name: friend.name) } %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
        <%= render "shared/pagination" %>
      <% else %>
        <div class="empty-state">
          <span class="empty-icon">🤝</span>
          <h3><%= t("friendships.no_friends") %></h3>
          <p><%= t("friendships.no_friends_hint") %></p>
          <%= link_to t("shared.explore_shops"), chicken_shops_path, class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
