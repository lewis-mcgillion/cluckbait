<% content_for(:title, "Add a Chicken Shop | Cluckbait") %>

<section class="section">
  <div class="container container-narrow">
    <h1 class="page-title">Add a Chicken Shop 🍗</h1>
    <p class="page-subtitle">Know a great spot? Add it to the map and help the community discover amazing chicken.</p>

    <%= form_with(model: @chicken_shop, class: "auth-form new-shop-form") do |f| %>
      <% if @chicken_shop.errors.any? %>
        <div class="form-errors">
          <p><strong><%= pluralize(@chicken_shop.errors.count, "error") %> prevented this shop from being saved:</strong></p>
          <% @chicken_shop.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="form-section">
        <h2 class="form-section-title">📍 Location</h2>
        <p class="form-section-hint">Click the map to place the shop, or use your current location. You can drag the marker to adjust.</p>

        <div data-controller="map-picker">
          <div class="map-picker-controls">
            <button type="button" class="btn btn-outline btn-sm" data-action="click->map-picker#locate">
              📍 Use My Location
            </button>
            <span class="map-picker-coords" data-map-picker-target="coordinates">No location selected</span>
          </div>

          <div class="map-picker-container" data-map-picker-target="container"></div>

          <%= f.hidden_field :latitude, data: { map_picker_target: "latitude" } %>
          <%= f.hidden_field :longitude, data: { map_picker_target: "longitude" } %>
        </div>
      </div>

      <div class="form-section">
        <h2 class="form-section-title">🏪 Shop Details</h2>

        <div class="form-group">
          <label class="form-label">Name *</label>
          <%= f.text_field :name, class: "form-input", placeholder: "e.g. Cluck Palace", autofocus: true %>
        </div>

        <div class="form-group">
          <label class="form-label">Address *</label>
          <%= f.text_field :address, class: "form-input", placeholder: "e.g. 42 High Street" %>
        </div>

        <div class="form-row">
          <div class="form-group form-group-half">
            <label class="form-label">City *</label>
            <%= f.text_field :city, class: "form-input", placeholder: "e.g. London" %>
          </div>

          <div class="form-group form-group-half">
            <label class="form-label">Postcode</label>
            <%= f.text_field :postcode, class: "form-input", placeholder: "e.g. SW1A 1AA" %>
          </div>
        </div>
      </div>

      <div class="form-section">
        <h2 class="form-section-title">📞 Contact & Info</h2>

        <div class="form-group">
          <label class="form-label">Phone</label>
          <%= f.text_field :phone, class: "form-input", placeholder: "e.g. 020 1234 5678" %>
        </div>

        <div class="form-group">
          <label class="form-label">Website</label>
          <%= f.text_field :website, class: "form-input", placeholder: "e.g. https://cluckpalace.co.uk" %>
        </div>

        <div class="form-group">
          <label class="form-label">Description</label>
          <%= f.text_area :description, class: "form-input form-textarea", rows: 4, placeholder: "Tell us about this place – what makes their chicken special?" %>
        </div>

        <div class="form-group">
          <label class="form-label">Photo</label>
          <%= f.file_field :image, class: "form-file-input", accept: "image/*" %>
        </div>
      </div>

      <%= f.submit "Add Chicken Shop 🍗", class: "btn btn-primary btn-block btn-lg" %>
    <% end %>

    <div class="form-footer">
      <%= link_to "← Back to shops", chicken_shops_path, class: "form-link" %>
    </div>
  </div>
</section>
