<% content_for(:title) { "#{@chicken_shop.name} — Cluckbait" } %>

<section class="shop-hero">
  <div class="shop-hero-bg">
    <% if @chicken_shop.image.attached? %>
      <%= image_tag @chicken_shop.image, class: "shop-hero-img" %>
    <% else %>
      <div class="shop-hero-placeholder"></div>
    <% end %>
  </div>
  <div class="shop-hero-overlay">
    <div class="container">
      <div class="shop-hero-content">
        <h1 class="shop-name"><%= @chicken_shop.name %></h1>
        <p class="shop-address">📍 <%= @chicken_shop.full_address %></p>
        <div class="shop-meta">
          <div class="shop-rating-large">
            <span class="rating-number"><%= @chicken_shop.average_rating %></span>
            <div class="rating-stars-large"><%= "★" * @chicken_shop.average_rating.floor %><%= "☆" * (5 - @chicken_shop.average_rating.floor) %></div>
            <span class="rating-count"><%= t("chicken_shops.show.reviews_count", count: @chicken_shop.reviews_count) %></span>
          </div>
          <% if @chicken_shop.phone.present? %>
            <div class="shop-contact">📞 <%= @chicken_shop.phone %></div>
          <% end %>
          <% safe_website_url = begin
               uri = URI.parse(@chicken_shop.website.to_s)
               uri.is_a?(URI::HTTP) ? uri.to_s : nil
             rescue URI::InvalidURIError, TypeError
               nil
             end %>
          <% if safe_website_url.present? %>
            <div class="shop-contact">🌐 <%= link_to t("shared.website"), safe_website_url, target: "_blank", rel: "noopener" %></div>
          <% end %>
        </div>
        <%= render "wishlist_items/wishlist_button", shop: @chicken_shop, wishlist_item: @wishlist_item %>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="shop-layout">
      <!-- Left column: Info + Review form -->
      <div class="shop-sidebar">
        <% if @chicken_shop.description.present? %>
          <div class="sidebar-card">
            <h3><%= t("chicken_shops.show.about") %></h3>
            <p><%= @chicken_shop.description %></p>
          </div>
        <% end %>

        <!-- Rating Distribution -->
        <div class="sidebar-card">
          <h3><%= t("chicken_shops.show.rating_breakdown") %></h3>
          <div class="rating-bars" data-controller="rating-bars">
            <% @chicken_shop.rating_distribution.reverse_each do |rating, count| %>
              <div class="rating-bar-row">
                <span class="rating-bar-label"><%= rating %> ★</span>
                <div class="rating-bar-track">
                  <div class="rating-bar-fill" data-width="<%= @chicken_shop.reviews_count > 0 ? (count.to_f / @chicken_shop.reviews_count * 100).round : 0 %>"></div>
                </div>
                <span class="rating-bar-count"><%= count %></span>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Map -->
        <div class="sidebar-card">
          <h3><%= t("chicken_shops.show.location") %></h3>
          <div class="shop-map"
               data-controller="shop-map"
               data-shop-map-lat-value="<%= @chicken_shop.latitude %>"
               data-shop-map-lng-value="<%= @chicken_shop.longitude %>"
               data-shop-map-name-value="<%= @chicken_shop.name %>">
          </div>
        </div>

        <!-- Write a Review -->
        <% if user_signed_in? && @user_review.nil? %>
          <div class="sidebar-card review-form-card" id="review-form">
            <h3><%= t("chicken_shops.show.write_review") %></h3>
            <%= form_with(model: [@chicken_shop, @review], class: "review-form", data: { turbo_frame: "reviews_list" }) do |f| %>
              <div class="form-group" data-controller="star-rating">
                <label class="form-label"><%= t("chicken_shops.show.your_rating") %></label>
                <%= f.hidden_field :rating, data: { star_rating_target: "input" }, value: 0 %>
                <div class="star-rating-input">
                  <% (1..5).each do |i| %>
                    <span class="star"
                          data-star-rating-target="star"
                          data-value="<%= i %>"
                          data-action="click->star-rating#select mouseenter->star-rating#hover mouseleave->star-rating#unhover">★</span>
                  <% end %>
                </div>
              </div>
              <div class="form-group">
                <label class="form-label"><%= t("chicken_shops.show.review_title") %></label>
                <%= f.text_field :title, class: "form-input", placeholder: t("chicken_shops.show.review_title_placeholder") %>
              </div>
              <div class="form-group">
                <label class="form-label"><%= t("chicken_shops.show.your_review") %></label>
                <%= f.text_area :body, class: "form-input form-textarea", rows: 5, placeholder: t("chicken_shops.show.review_body_placeholder") %>
              </div>
              <div class="form-group">
                <label class="form-label"><%= t("chicken_shops.show.photos_optional") %></label>
                <%= f.file_field :photos, multiple: true, class: "form-file-input", accept: "image/*" %>
              </div>
              <%= f.submit t("chicken_shops.show.post_review"), class: "btn btn-primary btn-block" %>
            <% end %>
          </div>
        <% elsif user_signed_in? && @user_review %>
          <div class="sidebar-card">
            <p class="text-muted"><%= t("chicken_shops.show.already_reviewed") %></p>
          </div>
        <% else %>
          <div class="sidebar-card">
            <p class="text-muted"><%= link_to t("shared.sign_in"), new_user_session_path %> <%= t("chicken_shops.show.sign_in_to_review") %></p>
          </div>
        <% end %>
      </div>

      <!-- Right column: Reviews -->
      <div class="shop-reviews">
        <%= turbo_frame_tag "reviews_list" do %>
        <div class="reviews-header">
          <h2 class="reviews-heading"><%= t("chicken_shops.show.reviews_heading", count: @chicken_shop.reviews_count) %></h2>
          <div class="review-sort-options" data-controller="search-filter">
            <span class="sort-label"><%= t("chicken_shops.show.sort") %></span>
            <% [["recent", t("chicken_shops.show.sort_recent")], ["highest_rated", t("chicken_shops.show.sort_highest")], ["lowest_rated", t("chicken_shops.show.sort_lowest")], ["most_helpful", t("chicken_shops.show.sort_helpful")]].each do |value, label| %>
              <%= link_to label,
                    chicken_shop_path(@chicken_shop, review_sort: value),
                    class: "sort-btn sort-btn-sm #{('sort-btn-active' if @review_sort == value)}",
                    data: { turbo_frame: "reviews_list" } %>
            <% end %>
          </div>
        </div>
          <% if @reviews.any? %>
            <% @reviews.each do |review| %>
              <%= render "reviews/review_card", review: review, chicken_shop: @chicken_shop %>
            <% end %>
            <%= render "shared/pagination" %>
          <% else %>
            <div class="empty-state">
              <span class="empty-icon">📝</span>
              <h3><%= t("chicken_shops.show.no_reviews") %></h3>
              <p><%= t("chicken_shops.show.be_first") %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</section>
