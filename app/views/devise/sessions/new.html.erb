<% content_for(:title) { "Sign In — Cluckbait" } %>

<div class="devise-container">
  <div class="devise-card">
    <h1 class="devise-title">Welcome back 🍗</h1>
    <p class="devise-subtitle">Sign in to your Cluckbait account</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <div class="form-group">
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input", placeholder: "you@example.com" %>
      </div>

      <div class="form-group">
        <%= f.label :password, class: "form-label" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "form-input", placeholder: "••••••••" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="form-group" style="display: flex; align-items: center; gap: 0.5rem;">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me, style: "font-size: 0.85rem; color: var(--text-secondary); margin: 0;" %>
        </div>
      <% end %>

      <%= f.submit "Sign In", class: "btn btn-primary btn-block btn-lg" %>
    <% end %>

    <div class="devise-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
