<% content_for(:title) { t("devise.passwords.edit.title") } %>

<div class="devise-container">
  <div class="devise-card">
    <h1 class="devise-title"><%= t("devise.passwords.edit.heading") %></h1>
    <p class="devise-subtitle"><%= t("devise.passwords.edit.subtitle") %></p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="form-group">
        <%= f.label :password, t("devise.passwords.edit.new_password"), class: "form-label" %>
        <% if @minimum_password_length %>
          <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.3rem;"><%= t("devise.password_chars_minimum", count: @minimum_password_length) %></p>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "form-input", placeholder: "••••••••" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, t("devise.passwords.edit.confirm_new_password"), class: "form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input", placeholder: "••••••••" %>
      </div>

      <%= f.submit t("devise.passwords.edit.submit"), class: "btn btn-primary btn-block" %>
    <% end %>

    <div class="devise-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
