<% content_for(:title) { "Join Cluckbait" } %>

<div class="devise-container">
  <div class="devise-card">
    <h1 class="devise-title">Join Cluckbait 🍗</h1>
    <p class="devise-subtitle">Create your free account and start reviewing</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="form-group">
        <%= f.label :display_name, "Display Name", class: "form-label" %>
        <%= f.text_field :display_name, autofocus: true, class: "form-input", placeholder: "ChickenFan99" %>
      </div>

      <div class="form-group">
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, autocomplete: "email", class: "form-input", placeholder: "you@example.com" %>
      </div>

      <div class="form-group">
        <%= f.label :password, class: "form-label" %>
        <% if @minimum_password_length %>
          <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.3rem;"><%= @minimum_password_length %> characters minimum</p>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-input", placeholder: "••••••••" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input", placeholder: "••••••••" %>
      </div>

      <%= f.submit "Create Account", class: "btn btn-primary btn-block btn-lg" %>
    <% end %>

    <div class="devise-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
