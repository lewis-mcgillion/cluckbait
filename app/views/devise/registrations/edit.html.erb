<% content_for(:title) { t("devise.registrations.edit.title") } %>

<div class="devise-container" style="max-width: 480px;">
  <div class="devise-card">
    <h1 class="devise-title"><%= t("devise.registrations.edit.heading") %></h1>
    <p class="devise-subtitle"><%= t("devise.registrations.edit.subtitle") %></p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="form-group">
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <p style="font-size: 0.85rem; color: var(--warning); margin-bottom: 1rem;">⚠️ Waiting confirmation for: <%= resource.unconfirmed_email %></p>
      <% end %>

      <div class="form-group">
        <%= f.label :password, t("devise.registrations.edit.new_password"), class: "form-label" %>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.3rem;"><%= t("devise.registrations.edit.password_leave_blank") %></p>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-input", placeholder: "••••••••" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, t("devise.registrations.edit.confirm_new_password"), class: "form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input", placeholder: "••••••••" %>
      </div>

      <div class="form-group">
        <%= f.label :current_password, class: "form-label" %>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.3rem;"><%= t("devise.registrations.edit.current_password_hint") %></p>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "form-input", placeholder: "••••••••" %>
      </div>

      <%= f.submit t("devise.registrations.edit.submit"), class: "btn btn-primary btn-block" %>
    <% end %>

    <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--border);">
      <h3 style="font-size: 0.95rem; color: var(--danger); margin-bottom: 0.5rem;"><%= t("devise.registrations.edit.danger_zone") %></h3>
      <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.75rem;"><%= t("devise.registrations.edit.danger_warning") %></p>
      <%= button_to t("devise.registrations.edit.delete_account"), registration_path(resource_name), method: :delete, class: "btn btn-danger btn-sm", data: { turbo_confirm: t("devise.registrations.edit.delete_confirm") } %>
    </div>

    <div class="devise-links" style="margin-top: 1.5rem;">
      <%= link_to "← Back", :back %>
    </div>
  </div>
</div>
