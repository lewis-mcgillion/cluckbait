<% if @page > 1 || @has_next_page %>
  <div class="admin-pagination">
    <% if @page > 1 %>
      <%= link_to "← Previous", url_for(request.query_parameters.merge(page: @page - 1)) %>
    <% else %>
      <span class="disabled">← Previous</span>
    <% end %>

    <span class="current">Page <%= @page %></span>

    <% if @has_next_page %>
      <%= link_to "Next →", url_for(request.query_parameters.merge(page: @page + 1)) %>
    <% else %>
      <span class="disabled">Next →</span>
    <% end %>
  </div>
<% end %>
