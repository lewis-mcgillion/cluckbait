<% content_for(:title) { "Edit #{@shop.name} — Admin" } %>

<%= link_to "← Back to Shop", admin_shop_path(@shop), class: "admin-back" %>

<div class="admin-header">
  <h1>Edit Shop</h1>
</div>

<div class="admin-detail-card admin-form-narrow">
  <%= form_with(model: @shop, url: admin_shop_path(@shop), class: "admin-form") do |f| %>
    <% if @shop.errors.any? %>
      <div class="form-errors">
        <p>Please fix the following errors:</p>
        <ul>
          <% @shop.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="field">
      <%= f.label :name %>
      <%= f.text_field :name %>
    </div>

    <div class="field">
      <%= f.label :address %>
      <%= f.text_field :address %>
    </div>

    <div class="admin-form-grid">
      <div class="field">
        <%= f.label :city %>
        <%= f.text_field :city %>
      </div>
      <div class="field">
        <%= f.label :postcode %>
        <%= f.text_field :postcode %>
      </div>
    </div>

    <div class="field">
      <%= f.label :phone %>
      <%= f.telephone_field :phone %>
    </div>

    <div class="field">
      <%= f.label :website %>
      <%= f.url_field :website %>
    </div>

    <div class="field">
      <%= f.label :description %>
      <%= f.text_area :description %>
    </div>

    <div class="admin-form-grid">
      <div class="field">
        <%= f.label :latitude %>
        <%= f.text_field :latitude %>
      </div>
      <div class="field">
        <%= f.label :longitude %>
        <%= f.text_field :longitude %>
      </div>
    </div>

    <div class="form-actions">
      <%= f.submit "Update Shop", class: "admin-btn admin-btn-primary" %>
      <%= link_to "Cancel", admin_shop_path(@shop), class: "admin-btn" %>
    </div>
  <% end %>
</div>
