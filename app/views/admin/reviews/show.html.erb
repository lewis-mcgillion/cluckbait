<% content_for(:title) { "Review ##{@review.id} — Admin" } %>

<%= link_to "← Back to Reviews", admin_reviews_path, class: "admin-back" %>

<div class="admin-header">
  <h1>Review #<%= @review.id %></h1>
  <div class="admin-header-actions">
    <%= button_to "Delete Review", admin_review_path(@review), method: :delete, class: "admin-btn admin-btn-danger",
          data: { turbo_confirm: "Are you sure you want to delete this review?" } %>
  </div>
</div>

<div class="admin-detail">
  <div>
    <div class="admin-detail-card">
      <h3>Review Content</h3>
      <div class="admin-detail-row">
        <span class="admin-detail-label">Rating</span>
        <span class="admin-detail-value"><%= "⭐" * @review.rating %> (<%= @review.rating %>/5)</span>
      </div>
      <div class="admin-detail-row">
        <span class="admin-detail-label">Title</span>
        <span class="admin-detail-value"><%= @review.title %></span>
      </div>
      <div class="admin-review-body">
        <div class="admin-detail-label">Body</div>
        <div class="admin-review-body-text">
          <%= simple_format(@review.body) %>
        </div>
      </div>
      <div class="admin-detail-row">
        <span class="admin-detail-label">Created</span>
        <span class="admin-detail-value"><%= @review.created_at.strftime("%d %b %Y at %H:%M") %></span>
      </div>
    </div>

    <%# Reactions %>
    <div class="admin-detail-card">
      <h3>Reactions (<%= @reactions.size %>)</h3>
      <% if @reactions.any? %>
        <% @reactions.each do |reaction| %>
          <div class="admin-detail-row">
            <span class="admin-detail-label"><%= reaction.user.name %></span>
            <span class="admin-detail-value"><%= reaction.kind %></span>
          </div>
        <% end %>
      <% else %>
        <div class="admin-empty">No reactions</div>
      <% end %>
    </div>
  </div>

  <div>
    <div class="admin-detail-card">
      <h3>Author</h3>
      <div class="admin-detail-row">
        <span class="admin-detail-label">Name</span>
        <span class="admin-detail-value">
          <%= link_to @review.user.name, admin_user_path(@review.user), class: "admin-link" %>
        </span>
      </div>
      <div class="admin-detail-row">
        <span class="admin-detail-label">Email</span>
        <span class="admin-detail-value"><%= @review.user.email %></span>
      </div>
      <div class="admin-detail-row">
        <span class="admin-detail-label">Total Reviews</span>
        <span class="admin-detail-value"><%= @review.user.reviews.size %></span>
      </div>
    </div>

    <div class="admin-detail-card">
      <h3>Shop</h3>
      <div class="admin-detail-row">
        <span class="admin-detail-label">Name</span>
        <span class="admin-detail-value">
          <%= link_to @review.chicken_shop.name, admin_shop_path(@review.chicken_shop), class: "admin-link" %>
        </span>
      </div>
      <div class="admin-detail-row">
        <span class="admin-detail-label">City</span>
        <span class="admin-detail-value"><%= @review.chicken_shop.city %></span>
      </div>
    </div>
  </div>
</div>
