<% content_for(:title) { "Edit Profile — Cluckbait" } %>

<section class="section">
  <div class="container container-narrow">
    <h1 class="page-title">Edit Profile</h1>

    <%= form_with(model: @user, url: profile_path(@user), method: :patch, class: "auth-form") do |f| %>
      <% if @user.errors.any? %>
        <div class="form-errors">
          <% @user.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="form-group" data-controller="avatar-upload">
        <label class="form-label">Avatar</label>
        <div class="avatar-upload">
          <% if @user.avatar.attached? %>
            <%= image_tag @user.avatar, class: "avatar-preview", data: { avatar_upload_target: "preview" } %>
          <% else %>
            <div class="avatar-preview-placeholder" data-avatar-upload-target="preview"><%= @user.name[0].upcase %></div>
          <% end %>
          <%= f.file_field :avatar, class: "form-file-input", accept: "image/*", data: { avatar_upload_target: "input", action: "change->avatar-upload#preview" } %>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Display Name</label>
        <%= f.text_field :display_name, class: "form-input", placeholder: "How should we call you?" %>
      </div>

      <div class="form-group">
        <label class="form-label">Bio</label>
        <%= f.text_area :bio, class: "form-input form-textarea", rows: 4, placeholder: "Tell us about yourself and your love of chicken burgers..." %>
      </div>

      <%= f.submit "Save Profile", class: "btn btn-primary btn-block" %>
    <% end %>

    <div class="form-footer">
      <%= link_to "← Back to profile", profile_path(@user), class: "form-link" %>
    </div>
  </div>
</section>
