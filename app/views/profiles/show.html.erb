<% content_for(:title) { t("profiles.show.title", name: @user.name) } %>

<section class="profile-hero">
  <div class="container">
    <div class="profile-header">
      <div class="profile-avatar-section">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar, class: "profile-avatar-large" %>
        <% else %>
          <div class="profile-avatar-placeholder-large"><%= @user.name[0].upcase %></div>
        <% end %>
      </div>
      <div class="profile-info">
        <h1 class="profile-name"><%= @user.name %></h1>
        <p class="profile-joined"><%= t("profiles.show.member_since", date: @user.created_at.strftime("%B %Y")) %></p>
        <% if @user.bio.present? %>
          <p class="profile-bio"><%= @user.bio %></p>
        <% end %>
        <div class="profile-stats">
          <div class="stat">
            <span class="stat-number"><%= @user.reviews_count %></span>
            <span class="stat-label"><%= t("profiles.show.reviews") %></span>
          </div>
          <div class="stat">
            <span class="stat-number"><%= @user.average_rating_given || "—" %></span>
            <span class="stat-label"><%= t("profiles.show.avg_rating") %></span>
          </div>
          <div class="stat">
            <span class="stat-number"><%= @user.wishlist_count %></span>
            <span class="stat-label"><%= t("profiles.show.wishlisted") %></span>
          </div>
        </div>
        <% if current_user == @user %>
          <%= link_to t("profiles.show.edit_profile"), edit_profile_path(@user), class: "btn btn-outline btn-sm" %>
        <% elsif user_signed_in? %>
          <div class="profile-actions">
            <% friendship = current_user.friendship_with(@user) %>
            <% if friendship.nil? %>
              <%= button_to t("profiles.show.add_friend"), friendships_path(friend_id: @user.id), method: :post, class: "btn btn-primary btn-sm" %>
            <% elsif friendship.accepted? %>
              <span class="friend-status-badge"><%= t("profiles.show.friends_badge") %></span>
              <%= button_to t("profiles.show.message"), conversations_path(receiver_id: @user.id), method: :post, class: "btn btn-primary btn-sm" %>
              <%= button_to t("profiles.show.unfriend"), friendship_path(friendship), method: :delete, class: "btn btn-outline btn-sm", data: { turbo_confirm: t("profiles.show.unfriend_confirm", name: @user.name) } %>
            <% elsif friendship.pending? && friendship.user == current_user %>
              <span class="friend-status-badge pending"><%= t("profiles.show.request_sent") %></span>
              <%= button_to t("profiles.show.cancel_request"), friendship_path(friendship), method: :delete, class: "btn btn-outline btn-sm" %>
            <% elsif friendship.pending? && friendship.friend == current_user %>
              <%= button_to t("profiles.show.accept_request"), friendship_path(friendship), method: :patch, class: "btn btn-primary btn-sm" %>
              <%= button_to t("shared.decline"), friendship_path(friendship), method: :delete, class: "btn btn-outline btn-sm" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<% if @user_badges.any? %>
<section class="section">
  <div class="container">
    <h2 class="section-title"><%= t("profiles.show.badges") %></h2>
    <div class="profile-badges">
      <% @user_badges.each do |user_badge| %>
        <div class="badge-chip" title="<%= user_badge.badge.name %>: <%= user_badge.badge.description %>">
          <span class="badge-icon"><%= user_badge.badge.icon %></span>
          <span class="badge-chip-name"><%= user_badge.badge.name %></span>
        </div>
      <% end %>
    </div>
    <%= link_to t("profiles.show.view_all_badges"), badges_path, class: "btn btn-outline btn-sm" %>
  </div>
</section>
<% end %>

<section class="section">
  <div class="container">
    <h2 class="section-title"><%= t("profiles.show.user_reviews", name: @user.name) %></h2>

    <% if @reviews.any? %>
      <div class="profile-reviews">
        <% @reviews.each do |review| %>
          <div class="review-card">
            <div class="review-header">
              <div class="review-shop-info">
                <%= link_to chicken_shop_path(review.chicken_shop), class: "review-shop-link" do %>
                  <strong>🍗 <%= review.chicken_shop.name %></strong>
                  <span class="review-shop-city">— <%= review.chicken_shop.city %></span>
                <% end %>
              </div>
              <div class="review-rating-badge">
                <span class="review-stars"><%= "★" * review.rating %><%= "☆" * (5 - review.rating) %></span>
              </div>
            </div>
            <h4 class="review-title"><%= review.title %></h4>
            <p class="review-body"><%= review.body %></p>
            <% if review.photos.attached? %>
              <div class="review-photos">
                <% review.photos.each do |photo| %>
                  <%= image_tag photo, class: "review-photo" %>
                <% end %>
              </div>
            <% end %>
            <span class="review-date"><%= review.created_at.strftime("%d %b %Y") %></span>
          </div>
        <% end %>
      </div>
      <%= render "shared/pagination" %>
    <% else %>
      <div class="empty-state">
        <span class="empty-icon">🍗</span>
        <h3><%= t("profiles.show.no_reviews") %></h3>
        <p><%= @user == current_user ? t("profiles.show.no_reviews_own") : t("profiles.show.no_reviews_other", name: @user.name) %></p>
        <% if @user == current_user %>
          <%= link_to t("shared.explore_shops"), chicken_shops_path, class: "btn btn-primary" %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2 class="section-title"><%= @user == current_user ? t("profiles.show.my_wishlist") : t("profiles.show.user_wishlist", name: @user.name) %></h2>

    <% if @wishlist_items.any? %>
      <div class="shops-grid">
        <% @wishlist_items.each do |item| %>
          <%= link_to chicken_shop_path(item.chicken_shop), class: "shop-card" do %>
            <div class="shop-card-image">
              <% if item.chicken_shop.image.attached? %>
                <%= image_tag item.chicken_shop.image, class: "shop-img" %>
              <% else %>
                <div class="shop-img-placeholder">
                  <span>🍔</span>
                </div>
              <% end %>
              <div class="shop-card-badge">
                <span class="shop-rating-badge">★ <%= item.chicken_shop.average_rating %></span>
              </div>
            </div>
            <div class="shop-card-body">
              <h3 class="shop-card-name"><%= item.chicken_shop.name %></h3>
              <p class="shop-card-location">📍 <%= item.chicken_shop.city %></p>
              <% if item.visited? %>
                <span class="wishlist-visited-badge"><%= t("profiles.show.visited") %></span>
              <% else %>
                <span class="wishlist-pending-badge"><%= t("profiles.show.want_to_try") %></span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <span class="empty-icon">🔖</span>
        <h3><%= t("profiles.show.no_wishlist") %></h3>
        <p><%= @user == current_user ? t("profiles.show.no_wishlist_own") : t("profiles.show.no_wishlist_other", name: @user.name) %></p>
        <% if @user == current_user %>
          <%= link_to t("shared.explore_shops"), chicken_shops_path, class: "btn btn-primary" %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
