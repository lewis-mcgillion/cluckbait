<% content_for(:title) { "#{@user.name}'s Profile — Cluckbait" } %>

<section class="profile-hero">
  <div class="container">
    <div class="profile-header">
      <div class="profile-avatar-section">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar, class: "profile-avatar-large" %>
        <% else %>
          <div class="profile-avatar-placeholder-large"><%= @user.name[0].upcase %></div>
        <% end %>
      </div>
      <div class="profile-info">
        <h1 class="profile-name"><%= @user.name %></h1>
        <p class="profile-joined">Member since <%= @user.created_at.strftime("%B %Y") %></p>
        <% if @user.bio.present? %>
          <p class="profile-bio"><%= @user.bio %></p>
        <% end %>
        <div class="profile-stats">
          <div class="stat">
            <span class="stat-number"><%= @user.reviews_count %></span>
            <span class="stat-label">Reviews</span>
          </div>
          <div class="stat">
            <span class="stat-number"><%= @user.average_rating_given %></span>
            <span class="stat-label">Avg Rating</span>
          </div>
          <div class="stat">
            <span class="stat-number"><%= @user.wishlist_count %></span>
            <span class="stat-label">Wishlisted</span>
          </div>
        </div>
        <% if current_user == @user %>
          <%= link_to "Edit Profile", edit_profile_path(@user), class: "btn btn-outline btn-sm" %>
        <% elsif user_signed_in? %>
          <div class="profile-actions">
            <% friendship = current_user.friendship_with(@user) %>
            <% if friendship.nil? %>
              <%= button_to "Add Friend 🤝", friendships_path(friend_id: @user.id), method: :post, class: "btn btn-primary btn-sm" %>
            <% elsif friendship.accepted? %>
              <span class="friend-status-badge">✅ Friends</span>
              <%= button_to "Message", conversations_path(receiver_id: @user.id), method: :post, class: "btn btn-primary btn-sm" %>
              <%= button_to "Unfriend", friendship_path(friendship), method: :delete, class: "btn btn-outline btn-sm", data: { turbo_confirm: "Remove #{@user.name} as a friend?" } %>
            <% elsif friendship.pending? && friendship.user == current_user %>
              <span class="friend-status-badge pending">⏳ Request Sent</span>
              <%= button_to "Cancel Request", friendship_path(friendship), method: :delete, class: "btn btn-outline btn-sm" %>
            <% elsif friendship.pending? && friendship.friend == current_user %>
              <%= button_to "Accept Request", friendship_path(friendship), method: :patch, class: "btn btn-primary btn-sm" %>
              <%= button_to "Decline", friendship_path(friendship), method: :delete, class: "btn btn-outline btn-sm" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2 class="section-title">📝 <%= @user.name %>'s Reviews</h2>

    <% if @reviews.any? %>
      <div class="profile-reviews">
        <% @reviews.each do |review| %>
          <div class="review-card">
            <div class="review-header">
              <div class="review-shop-info">
                <%= link_to chicken_shop_path(review.chicken_shop), class: "review-shop-link" do %>
                  <strong>🍗 <%= review.chicken_shop.name %></strong>
                  <span class="review-shop-city">— <%= review.chicken_shop.city %></span>
                <% end %>
              </div>
              <div class="review-rating-badge">
                <span class="review-stars"><%= "★" * review.rating %><%= "☆" * (5 - review.rating) %></span>
              </div>
            </div>
            <h4 class="review-title"><%= review.title %></h4>
            <p class="review-body"><%= review.body %></p>
            <% if review.photos.attached? %>
              <div class="review-photos">
                <% review.photos.each do |photo| %>
                  <%= image_tag photo, class: "review-photo" %>
                <% end %>
              </div>
            <% end %>
            <span class="review-date"><%= review.created_at.strftime("%d %b %Y") %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <span class="empty-icon">🍗</span>
        <h3>No reviews yet</h3>
        <p><%= @user == current_user ? "You haven't written any reviews yet. Find a chicken shop and share your thoughts!" : "#{@user.name} hasn't written any reviews yet." %></p>
        <% if @user == current_user %>
          <%= link_to "Explore Shops", chicken_shops_path, class: "btn btn-primary" %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2 class="section-title">🔖 <%= @user == current_user ? "My" : "#{@user.name}'s" %> Wishlist</h2>

    <% if @wishlist_items.any? %>
      <div class="shops-grid">
        <% @wishlist_items.each do |item| %>
          <%= link_to chicken_shop_path(item.chicken_shop), class: "shop-card" do %>
            <div class="shop-card-image">
              <% if item.chicken_shop.image.attached? %>
                <%= image_tag item.chicken_shop.image, class: "shop-img" %>
              <% else %>
                <div class="shop-img-placeholder">
                  <span>🍔</span>
                </div>
              <% end %>
              <div class="shop-card-badge">
                <span class="shop-rating-badge">★ <%= item.chicken_shop.average_rating %></span>
              </div>
            </div>
            <div class="shop-card-body">
              <h3 class="shop-card-name"><%= item.chicken_shop.name %></h3>
              <p class="shop-card-location">📍 <%= item.chicken_shop.city %></p>
              <% if item.visited? %>
                <span class="wishlist-visited-badge">✅ Visited</span>
              <% else %>
                <span class="wishlist-pending-badge">🍗 Want to Try</span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <span class="empty-icon">🔖</span>
        <h3>No wishlist items yet</h3>
        <p><%= @user == current_user ? "Save chicken shops you want to try!" : "#{@user.name} hasn't saved any shops yet." %></p>
        <% if @user == current_user %>
          <%= link_to "Explore Shops", chicken_shops_path, class: "btn btn-primary" %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
