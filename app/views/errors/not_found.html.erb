<% content_for(:title) { t("errors.not_found.title") } %>

<div class="empty-state" style="padding: 4rem 1rem;">
  <span class="empty-icon">🍗</span>
  <h1><%= t("errors.not_found.heading") %></h1>
  <p><%= t("errors.not_found.message") %></p>
  <div style="margin-top: 1.5rem; display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
    <%= link_to t("errors.not_found.go_home"), root_path, class: "btn btn-primary" %>
    <%= link_to t("errors.not_found.browse_shops"), chicken_shops_path, class: "btn btn-outline" %>
  </div>
</div>
