<% content_for(:title) { t("wishlist.title") } %>

<div class="page-header">
  <div class="container">
    <h1 class="page-title"><%= t("wishlist.heading") %></h1>
    <p class="page-subtitle"><%= t("wishlist.subtitle") %></p>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="wishlist-tabs">
      <%= link_to t("wishlist.tab_all"), wishlist_items_path, class: "wishlist-tab #{'active' if @filter == 'all'}" %>
      <%= link_to t("wishlist.tab_want_to_try"), wishlist_items_path(filter: "want_to_try"), class: "wishlist-tab #{'active' if @filter == 'want_to_try'}" %>
      <%= link_to t("wishlist.tab_visited"), wishlist_items_path(filter: "visited"), class: "wishlist-tab #{'active' if @filter == 'visited'}" %>
    </div>

    <% if @wishlist_items.any? %>
      <div class="shops-grid" id="wishlist-items">
        <% @wishlist_items.each do |item| %>
          <div class="wishlist-card-wrapper" id="<%= dom_id(item) %>">
            <%= link_to chicken_shop_path(item.chicken_shop), class: "shop-card" do %>
              <div class="shop-card-image">
                <% if item.chicken_shop.image.attached? %>
                  <%= image_tag item.chicken_shop.image, class: "shop-img", alt: item.chicken_shop.name %>
                <% else %>
                  <div class="shop-img-placeholder">
                    <span>🍔</span>
                  </div>
                <% end %>
                <div class="shop-card-badge">
                  <span class="shop-rating-badge">★ <%= item.chicken_shop.average_rating %></span>
                </div>
              </div>
              <div class="shop-card-body">
                <h3 class="shop-card-name"><%= item.chicken_shop.name %></h3>
                <p class="shop-card-location">📍 <%= item.chicken_shop.city %><%= ", #{item.chicken_shop.postcode}" if item.chicken_shop.postcode.present? %></p>
                <div class="shop-card-stats">
                  <span class="shop-reviews-count"><%= t("chicken_shops.card.reviews", count: item.chicken_shop.reviews_count) %></span>
                  <span class="shop-card-stars"><%= "★" * item.chicken_shop.average_rating.floor %><%= "☆" * (5 - item.chicken_shop.average_rating.floor) %></span>
                </div>
              </div>
            <% end %>
            <div class="wishlist-card-actions">
              <% if item.visited? %>
                <span class="wishlist-visited-badge"><%= t("wishlist.visited") %></span>
              <% else %>
                <span class="wishlist-pending-badge"><%= t("wishlist.want_to_try") %></span>
              <% end %>
              <%= button_to wishlist_item_path(item), method: :patch, class: "btn btn-sm btn-outline wishlist-toggle-btn" do %>
                <%= item.visited? ? t("wishlist.mark_unvisited") : t("wishlist.mark_visited") %>
              <% end %>
              <%= button_to wishlist_item_path(item), method: :delete, class: "btn btn-sm btn-danger wishlist-remove-btn", data: { turbo_confirm: t("wishlist.remove_confirm") } do %>
                <%= t("shared.remove") %>
              <% end %>
            </div>
            <% if item.notes.present? %>
              <div class="wishlist-card-notes">
                <p>📝 <%= item.notes %></p>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
      <%= render "shared/pagination" %>
    <% else %>
      <div class="empty-state">
        <span class="empty-icon">🔖</span>
        <h3><%= @filter == "visited" ? t("wishlist.empty_visited") : @filter == "want_to_try" ? t("wishlist.empty_want_to_try") : t("wishlist.empty_all") %></h3>
        <p><%= t("wishlist.empty_hint") %></p>
        <%= link_to t("shared.explore_shops"), chicken_shops_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</section>
